# Kona v56 - Environment Variables
# Copy to .env and fill in values

# Polygon.io API key (required)
POLYGON_API_KEY=your_polygon_api_key_here

# Anthropic API key (for King Kam chatbot)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Email alerts (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
FROM_EMAIL=
TO_EMAIL=

# File paths (defaults are fine for EC2)
# KONA_STATE_FILE=kona_state.json
# KONA_CONTROLS_FILE=kona_controls.json
# KONA_EARNINGS_CACHE=earnings_cache.json
# KONA_UNIVERSE_FILE=top_300_options_liquidity_companies_polygon.csv
