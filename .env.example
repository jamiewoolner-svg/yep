# Example of environment variables for the stock scanner tool

# API keys for data providers
API_KEY_PROVIDER_1=your_api_key_here
API_KEY_PROVIDER_2=your_api_key_here

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=your_username
DB_PASSWORD=your_password
DB_NAME=your_database_name

# Notification settings
NOTIFICATION_EMAIL=your_email@example.com
NOTIFICATION_THRESHOLD=1000

# Other configuration
LOG_LEVEL=info
SCAN_INTERVAL=60000  # in milliseconds