# ═══════════════════════════════════════════════════════════════
# Big Island Webapp — Environment Variables
# Copy to .env and fill in values
# ═══════════════════════════════════════════════════════════════

# Path to Kona engine state directory (shared files on EC2)
KONA_STATE_DIR=/home/ec2-user/kona_aws

# Polygon.io API key (market data for scanner/waves)
POLYGON_API_KEY=

# Anthropic API key (King Kam chatbot)
ANTHROPIC_API_KEY=

# WebAuthn / Passkey auth
BI_RP_ID=
BI_PIN=
BI_SECRET=

# Scanner data source (polygon or mock)
SCANNER_DATA_SOURCE=polygon

# Polygon rate-limit gap (seconds between API calls)
POLYGON_MIN_GAP_SEC=15
